# EpiBridge — environment configuration
# Copy to .env and customise for your deployment.
#
# Values set to __GENERATED__ are replaced automatically by install.sh
# with cryptographically secure random values.

#################################
# PostgreSQL
#################################
POSTGRES_DB=epibridge
POSTGRES_USER=epibridge
POSTGRES_PASSWORD=__GENERATED__
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

#################################
# Redis
#################################
REDIS_PASSWORD=__GENERATED__
REDIS_HOST=redis
REDIS_PORT=6379

#################################
# Application
#################################
SECRET_KEY=__GENERATED__
PUBLIC_URL=https://localhost
ADMIN_EMAIL=admin@epibridge.local
ADMIN_PASSWORD=__GENERATED__

#################################
# Email (optional, disabled by default)
# Set EMAIL_ENABLED=true and configure SMTP to enable notifications.
# When disabled, email content is logged and suppressed.
#################################
# EMAIL_ENABLED=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_TLS=true
# SMTP_FROM=noreply@example.org
# SMTP_FROM_NAME=EpiBridge

#################################
# Session & Auth (optional overrides)
#################################
# SECURE_COOKIE=false
# SESSION_TTL_SECONDS=86400
# MAX_SESSION_TTL_SECONDS=604800
# RATE_LIMIT_MAX_ATTEMPTS=10
# RATE_LIMIT_WINDOW_SECONDS=300

#################################
# Host data root (optional)
# DATA_ROOT is the runtime path used by Providers.
# HOST_DATA_ROOT is its host-visible equivalent for execution
# backends that perform host-side bind mounts (e.g. DockerExecutor).
# Development: docker-compose sets this automatically.
#################################
# HOST_DATA_ROOT=

#################################
# AI assistance (optional)
# Requires: docker compose --profile ai up
# Models are installed manually by an administrator:
#   docker compose exec ollama ollama pull llama3.2
#################################
# AI_ASSIST_ENABLED=false
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2

#################################
# Manifest directories (optional)
# Development: docker-compose sets these automatically.
# Production: override to point at institutional YAML manifests.
#################################
# RESOURCE_MANIFEST_DIR=
# ENVIRONMENT_MANIFEST_DIR=

#################################
# Educational publication directories (optional)
# Repository-backed institutional guidance.
# Development: docker-compose sets these automatically.
#################################
# EXAMPLE_ANALYSIS_DIR=
# TEMPLATE_DIR=

#################################
# Docker (generated by bootstrap.sh)
# DOCKER_GID is automatically discovered and written to .env by bootstrap.sh.
# It is required by the worker service for Docker-outside-of-Docker bind mounts.
#################################
# DOCKER_GID=
